{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "branchConcurrentLimit": 1,
  "prHourlyLimit": 10,
  "minimumReleaseAge": "1 day",
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github\\/actions\\/setup\\/action\\.yml$/"],
      "matchStrings": [
        "uses: jdx\\/mise-action@\\S+(?:\\s+#.*)?\\s+      with:\\s+        version: (?<currentValue>\\S+)"
      ],
      "depNameTemplate": "jdx/mise",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver-coerced"
    }
  ],
  "packageRules": [
    {
      "groupName": "nushell parser packages",
      "matchManagers": ["cargo"],
      "matchDepNames": ["nu-parser", "nu-protocol"]
    },
    {
      "groupName": "vite-plus",
      "matchDepNames": ["vite", "vitest", "vite-plus", "viteplus"],
      "matchPackageNames": [
        "vite-plus",
        "viteplus",
        "@voidzero-dev/vite-plus-core",
        "@voidzero-dev/vite-plus-test"
      ]
    },
    {
      "matchPackageNames": ["jdx/mise"],
      "matchDatasources": ["github-releases"],
      "ignoreUnstable": true,
      "dependencyDashboardApproval": true
    },
    {
      "matchManagers": ["github-actions"],
      "dependencyDashboardApproval": true
    },
    {
      "matchPackageNames": ["@typescript/*"],
      "minimumReleaseAge": null
    }
  ]
}
