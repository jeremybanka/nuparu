#!/bin/sh

set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
workspace_dir=$(CDPATH= cd -- "$script_dir/../.." && pwd)
self_path="$script_dir/just-lsp"

if command -v just-lsp >/dev/null 2>&1; then
  found_just_lsp=$(command -v just-lsp)
  if [ "$found_just_lsp" != "$self_path" ]; then
    export PATH="$workspace_dir/.vscode/bin:$PATH"
    exec "$found_just_lsp" "$@"
  fi
fi

if [ -x "$HOME/.cargo/bin/just-lsp" ]; then
  export PATH="$workspace_dir/.vscode/bin:$PATH"
  exec "$HOME/.cargo/bin/just-lsp" "$@"
fi

mise_root="$HOME/.local/share/mise/installs/github-terror-just-lsp"
if [ -d "$mise_root" ]; then
  mise_just_lsp=$(
    find "$mise_root" -path '*/just-lsp' -type f 2>/dev/null | sort | tail -n 1
  )
  if [ -n "${mise_just_lsp:-}" ] && [ -x "$mise_just_lsp" ]; then
    export PATH="$workspace_dir/.vscode/bin:$PATH"
    exec "$mise_just_lsp" "$@"
  fi
fi

printf '%s\n' "Unable to find just-lsp. Install it with mise or cargo, then reopen VS Code." >&2
exit 1
