{
  "name": "nuparu-vscode",
  "displayName": "nuparu",
  "version": "0.1.0",
  "description": "Format Nushell files with nuparu.",
  "categories": [
    "Formatters"
  ],
  "keywords": [
    "formatter",
    "nu",
    "nuparu",
    "nushell"
  ],
  "license": "MIT",
  "author": "jeremybanka",
  "publisher": "jeremybanka",
  "files": [
    "dist",
    "icon.png",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "type": "module",
  "main": "./dist/extension.cjs",
  "scripts": {
    "build": "vp pack",
    "visx": "pnpm run build && node __scripts__/vscode-package.node.ts",
    "dev": "vp pack --watch",
    "check": "vp check",
    "test": "vp test",
    "vscode:install": "pnpm run visx && node __scripts__/vscode-install.node.ts"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/vscode": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vscode/vsce": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "contributes": {
    "languages": [
      {
        "id": "nushell",
        "aliases": [
          "Nushell",
          "nushell"
        ],
        "extensions": [
          ".nu"
        ]
      }
    ],
    "commands": [
      {
        "command": "nuparu.formatDocument",
        "title": "Format Current Nushell File",
        "category": "nuparu"
      }
    ],
    "configuration": {
      "title": "nuparu",
      "properties": {
        "nuparu.path": {
          "type": "string",
          "default": "",
          "description": "Path to the nuparu executable. Leave empty to auto-discover common locations."
        },
        "nuparu.extraArgs": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional arguments passed to nuparu."
        }
      }
    }
  },
  "activationEvents": [
    "onCommand:nuparu.formatDocument",
    "onLanguage:nushell"
  ],
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.100.0"
  },
  "packageManager": "pnpm@11.1.2"
}
